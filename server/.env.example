# Mandata server config
# Copy this file to .env and fill in real values.

# --- Claude (Anthropic) ---
# Anthropic API key. If unset, Claude calls fall back to a retrieval-only
# "demo mode" response.
ANTHROPIC_API_KEY=

# --- Llama (defaults to Groq's hosted Llama, OpenAI-compatible) ---
# In production / Railway you only need to set LLAMA_API_KEY. Get one free at
# https://console.groq.com/keys — Groq hosts Llama 3.1-8B and Llama 3.3-70B.
LLAMA_API_KEY=

# Override the base URL only if you want a different provider.
#   Groq (default)     https://api.groq.com/openai/v1
#   Together AI        https://api.together.xyz/v1
#   Ollama (local dev) http://localhost:11434/v1
#   self-hosted vLLM   http://my-vllm.internal:8000/v1
# LLAMA_BASE_URL=https://api.groq.com/openai/v1

# Server port (Railway sets this automatically).
# PORT=4000
